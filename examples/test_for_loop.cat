# CatBase for 循环综合示例
#
# 演示 CatBase 中 for 循环的常见用法，以及与 while 循环的对比。
# 注意：CatBase 是强类型语言，不支持类型推断。
#       for 循环的变量类型目前推断为 unknown，
#       因此 for 循环变量只能用于索引访问，不能直接做算术运算。
#       需要算术运算时，请使用 while 循环配合预声明变量。

# ---------------------------------------------------------------------------
# 示例 1: 最简单的 for 循环 - 仅做索引访问
# ---------------------------------------------------------------------------

def basic_for_loop() {
    print("=== 示例 1: 基本 for 循环 ===\n")

    # 遍历 0..4，变量 i 只用作索引（访问数组）
    fruits: list[str] = ["apple", "banana", "orange", "grape", "pear"]
    for i in range(0, len(fruits)) {
        print("fruits[", i, "] = ", fruits[i], "\n")
    }
}

# ---------------------------------------------------------------------------
# 示例 2: range(start, end) 形式
# ---------------------------------------------------------------------------

def range_with_start() {
    print("\n=== 示例 2: range(start, end) ===\n")

    # 从 1 遍历到 4（不包含 5）
    for i in range(1, 5) {
        print("i = ", i, "\n")
    }
}

# ---------------------------------------------------------------------------
# 示例 3: for 循环变量不参与算术运算 - 计算数组元素之和（用辅助变量）
# ---------------------------------------------------------------------------

def sum_with_for() {
    print("\n=== 示例 3: for 循环求和（用辅助变量）===\n")

    nums: list[int] = [10, 20, 30, 40, 50]
    total: int = 0  # 累加器在循环外声明

    for i in range(0, len(nums)) {
        total = total + nums[i]   # nums[i] 是 int，可以算术
    }

    print("sum = ", total, "\n")
}

# ---------------------------------------------------------------------------
# 示例 4: 需要对循环变量做算术运算 - 必须用 while
# ---------------------------------------------------------------------------

def arithmetic_with_while() {
    print("\n=== 示例 4: 算术运算用 while ===\n")

    # 打印 0, 2, 4, 6, 8 (步长 2)
    i: int = 0
    while i < 10 {
        print("i = ", i, "\n")
        i = i + 2
    }
}

# ---------------------------------------------------------------------------
# 示例 5: for + while 嵌套 - 外层 while 算术，内层 for 索引
# ---------------------------------------------------------------------------

def nested_loops() {
    print("\n=== 示例 5: 嵌套循环（外层 while + 内层 for）===\n")

    # 打印 3x3 矩阵
    row: int = 0
    while row < 3 {
        col: int = 0
        while col < 3 {
            print("(", row, ",", col, ") ")
            col = col + 1
        }
        print("\n")
        row = row + 1
    }
}

# ---------------------------------------------------------------------------
# 示例 6: for 循环遍历字符串列表
# ---------------------------------------------------------------------------

def iterate_strings() {
    print("\n=== 示例 6: for 遍历字符串 ===\n")

    greetings: list[str] = ["Hello", "Bonjour", "Hola", "Konnichiwa"]
    for i in range(0, len(greetings)) {
        print(i, ": ", greetings[i], "\n")
    }
}

# ---------------------------------------------------------------------------
# 示例 7: for 循环查找
# ---------------------------------------------------------------------------

def find_with_for() {
    print("\n=== 示例 7: for 循环查找 ===\n")

    target: str = "orange"
    fruits: list[str] = ["apple", "banana", "orange", "grape", "pear"]
    found_index: int = -1

    for i in range(0, len(fruits)) {
        if fruits[i] == target {
            found_index = i
        }
    }

    print("Found '", target, "' at index: ", found_index, "\n")
}

# ---------------------------------------------------------------------------
# 示例 8: 累计器模式（推荐写法）
# ---------------------------------------------------------------------------

def accumulator_pattern() {
    print("\n=== 示例 8: 累计器模式 ===\n")

    # 计算 1+2+3+...+10
    sum_outer: int = 0
    i: int = 1
    while i <= 10 {
        sum_outer = sum_outer + i
        i = i + 1
    }
    print("1+2+...+10 = ", sum_outer, "\n")
}

# ---------------------------------------------------------------------------
# 主函数
# ---------------------------------------------------------------------------

def main(args: list[str]) {
    print("============================================\n")
    print("  CatBase for 循环综合示例\n")
    print("============================================\n")

    basic_for_loop()
    range_with_start()
    sum_with_for()
    arithmetic_with_while()
    nested_loops()
    iterate_strings()
    find_with_for()
    accumulator_pattern()

    print("\n============================================\n")
    print("  所有示例运行完成！\n")
    print("============================================\n")
}

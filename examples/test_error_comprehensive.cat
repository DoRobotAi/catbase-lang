def main(args:list[str]) {
    # 测试算术运算类型错误
    x:str = "hello"
    y:int = 5
    z = x + y  # 错误：字符串不能与整数相加
    
    # 测试逻辑运算类型错误
    a:int = 10
    b = not a  # 错误：not 需要布尔类型
    c = a && True  # 错误：&& 需要布尔类型
    
    # 测试比较运算类型错误
    d = "hello" > 5  # 错误：不能比较字符串和整数
    
    # 测试一元运算类型错误
    e:str = "test"
    f = -e  # 错误：一元负号需要数值类型
    
    # 测试列表索引类型错误
    lst:list[int] = [1, 2, 3]
    g = lst["hello"]  # 错误：列表索引必须是整数
    
    # 测试字典索引类型错误
    dic:dict[str, int] = {"a": 1, "b": 2}
    h = dic[5]  # 错误：字典索引必须是字符串
    
    # 测试字符串拼接类型错误
    i:str = "hello"
    j:int = 5
    k = i + j  # 错误：字符串拼接需要两个字符串
    
    print("done")
}

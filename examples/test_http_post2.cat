def main(args:list[str]) {
    url:str = "http://localhost:8000"
    headers:str = ""
    data:dict[str,any] = {"username": "admin", "password": "123456"}
    body:str = ""
    timeout:int = 30
    stream:bool = False
    
    response:Response = http_post(url, headers, data, body, timeout, stream)
    print("Response status: ")
    print(response.status_code)
    print("\n")
    print("Response body: ")
    print(response.body)
    print("\n")
}
